{
  "name": "@oxian/oxian-js",
  "version": "0.15.0",
  "exports": {
    ".": "./cli.ts",
    "./types": "./src/types.ts",
    "./mcp": "./src/utils/mcp.ts"
  },
  "publish": {
    "include": [
      "cli.ts",
      "llm.txt",
      "src/**",
      "deno.json",
      "docs/**",
      "README.md",
      "LICENSE*",
      "llm.txt"
    ],
    "exclude": [
      "tests/**",
      "routes/**",
      "oxian-framework-spec.md"
    ]
  },
  "imports": {
    "oxian-js/": "./src/",
    "@oxian/oxian-js": "./cli.ts",
    "@oxian/oxian-js/mcp": "./src/utils/mcp.ts",
    "@std/path": "jsr:@std/path@1.1.1",
    "@std/cli/parse-args": "jsr:@std/cli@1.0.21/parse-args",
    "@std/encoding/base64": "jsr:@std/encoding@1.0.5/base64",
    "opentelemetry": "npm:@opentelemetry/api@1"
  },
  "lock": false
}
